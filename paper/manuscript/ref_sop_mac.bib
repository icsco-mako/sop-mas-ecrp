@inproceedings{hongMetaGPTMetaProgramming2023a,
  title = {{{MetaGPT}}: {{Meta Programming}} for {{A Multi-Agent Collaborative Framework}}},
  shorttitle = {{{MetaGPT}}},
  booktitle = {International {{Conference}} on {{Learning Representations}}},
